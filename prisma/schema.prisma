generator client {
  provider = "prisma-client"
  output   = "../lib/prisma"
}

generator zod {
  provider = "prisma-zod-generator"
  output   = "../lib/validator"
}

datasource db {
  provider = "postgresql"
}

model CollegeAdmin {
  id        String  @id @default(uuid())
  name      String
  email     String  @unique
  password  String
  phone     String?
  collegeId String  @unique
  college   College @relation(fields: [collegeId], references: [id])
}

model College {
  id                   String             @id @default(uuid())
  name                 String             @unique
  city                 String
  state                String
  collegeType          CollegeType?
  logoUrl              String?
  websiteUrl           String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  country              String             @default("India")
  accrediation         String?
  address              String?
  affiliatedUniversity String?
  deletedAt            DateTime?
  establisedYear       Int?
  latitude             String?
  longitude            String?
  officialEmail        String?
  phone                String?
  pincode              String?
  regitrationNumber    String?
  verificationNote     String?
  verififedTime        DateTime?
  verified             VerificationStatus @default(PENDING)
  clubs                Club[]
  admin                CollegeAdmin?
  faculty              Faculty[]
  students             Student[]
  followers            Student[]          @relation("StudentFollows")
}

model Club {
  id           String          @id @default(uuid())
  name         String
  collegeId    String
  description  String?
  cordinatorId String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  deletedAt    DateTime?
  onHold       Boolean         @default(true)
  category     String
  college      College         @relation(fields: [collegeId], references: [id])
  coordinator  Faculty?        @relation(fields: [cordinatorId], references: [id])
  events       Event[]
  role         RoleInClub[]
  students     StudentInClub[]
  clubAdmin    clubAdmin?
  followers    Student[]       @relation("StudentFollowsClub")

  @@unique([collegeId, name])
}

model Student {
  id            String          @id @default(uuid())
  name          String
  email         String          @unique
  password      String
  rollnumber    String          @unique
  collegeId     String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?
  registrations Registrations[]
  college       College?        @relation(fields: [collegeId], references: [id])
  clubs         StudentInClub[]
  follows       College[]       @relation("StudentFollows")
  followsClub   Club[]          @relation("StudentFollowsClub")
}

model StudentInClub {
  id        String     @id @default(uuid())
  clubId    String
  studentId String
  roleId    String
  status    status     @default(PENDING)
  club      Club       @relation(fields: [clubId], references: [id])
  role      RoleInClub @relation(fields: [roleId], references: [id])
  student   Student    @relation(fields: [studentId], references: [id])

  @@unique([clubId, studentId])
}

model Faculty {
  id        String    @id @default(uuid())
  name      String
  collegeId String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  email     String    @unique
  password  String
  club      Club[]
  college   College   @relation(fields: [collegeId], references: [id])
}

model RoleInClub {
  id      String          @id @default(uuid())
  name    String
  clubId  String
  club    Club            @relation(fields: [clubId], references: [id])
  members StudentInClub[]

  @@unique([name, clubId])
}

model clubAdmin {
  id        String @id @default(uuid())
  firstName String
  lastName  String
  email     String @unique
  password  String
  clubId    String @unique
  club      Club   @relation(fields: [clubId], references: [id])
}

model Event {
  id                   String          @id @default(uuid())
  name                 String
  description          String?
  clubId               String
  date                 DateTime
  time                 String
  mode                 mode
  registrationLink     String?
  registrationFee      Int?
  registrationOpen     Boolean         @default(false)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  deletedAt            DateTime?
  venue                String?
  city                 String?
  banner               String?
  capacity             Int?
  registrationDeadline DateTime?
  status               eventStatus     @default(UPCOMING)
  isPublic             Boolean         @default(false)
  category             String
  club                 Club            @relation(fields: [clubId], references: [id])
  registrations        Registrations[]
}

model Registrations {
  id        String    @id @default(uuid())
  studentId String
  eventId   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  event     Event     @relation(fields: [eventId], references: [id])
  student   Student   @relation(fields: [studentId], references: [id])
}

enum status {
  PENDING
  ACCEPTED
  REJECTED
}

enum mode {
  ONLINE
  OFFLINE
  HYBRID
}

enum VerificationStatus {
  PENDING
  UNDER_REVIEW
  VERIFIED
  REJECTED
}

enum eventStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum CollegeType {
  GOVERNMENT
  PRIVATE
  AUTONOMOUS
  DEEMED
}
